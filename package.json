{
  "name": "mcp-clickup-server",
  "version": "1.1.8",
  "description": "MCP server para integrar ClickUp con OpenCode/Gentle AI — creá tareas y explorá tu workspace desde lenguaje natural",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "mcp-clickup-server": "bin/mcp-clickup-server.cjs"
  },
  "files": [
    "dist/",
    "scripts/",
    "bin/",
    ".env.example",
    "README.md"
  ],
  "keywords": [
    "clickup",
    "mcp",
    "opencode",
    "gentle-ai",
    "task-management"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Bit9-A/MCP-CLICKUP.git"
  },
  "homepage": "https://github.com/Bit9-A/MCP-CLICKUP",
  "scripts": {
    "setup": "node scripts/setup.mjs",
    "dev": "node --env-file .env --import tsx src/index.ts",
    "build": "npx tsc --project .",
    "postinstall": "test -f dist/index.js || npx tsc",
    "start": "node --env-file .env dist/index.js",
    "update": "node bin/mcp-clickup-server.cjs update",
    "prestart": "node -e \"require('fs').existsSync('.env') || (console.error('❌ Creá el .env primero: npm run setup'), process.exit(1))\""
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "axios": "^1.18.1",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/node": "^26.0.0",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3"
  }
}
